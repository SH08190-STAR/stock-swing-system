# fly.toml.example — Toss Relay 배포 의도 문서 (실배포 시 fly.toml로 복사 후 app 이름 교체)
#
# 배포는 저장소 루트에서 실행 (빌드 컨텍스트에 app/toss.py 포함 필요):
#   fly deploy . --config services/toss_relay/fly.toml --ha=false
#
# Machine 수 상한(fly.toml에는 max 키가 없음 — 운영 절차로 강제):
#   fly scale count 1 --app <APP_NAME>
# 이유: Toss는 클라이언트당 활성 토큰 1개 → Machine 2대면 토큰이 서로 무효화됨.

app = "REPLACE-WITH-RELAY-APP-NAME"     # placeholder — 실제 앱 이름은 fly.toml에만
primary_region = "nrt"                  # Tokyo

[build]
  # 주의: 이 경로는 fly.toml "위치" 기준 상대경로다(빌드 컨텍스트 기준 아님).
  # 실배포에서 검증된 값 — services/toss_relay/Dockerfile로 중복 결합하면 배포 실패.
  dockerfile = "Dockerfile"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = "off"            # 항상 실행 (중지/재시작 없이 상시 대기)
  auto_start_machines = true
  min_machines_running = 1

  [[http_service.checks]]
    grace_period = "10s"
    interval = "30s"
    timeout = "5s"
    method = "GET"
    path = "/healthz"

[[vm]]
  size = "shared-cpu-1x"
  memory = "256mb"
